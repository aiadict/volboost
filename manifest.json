{
  "manifest_version": 3,
  "name": "Volume Booster — Safe Tab Audio Amplifier",
  "version": "1.0.1",
  "description": "Amplify browser tab audio safely up to 600%. No adware, no tracking, 100% local. Works on YouTube, Spotify, Netflix and any website.",
  "permissions": [
    "activeTab",
    "storage",
    "tabCapture",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Volume Booster — Safe Tab Audio Amplifier"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/fullscreen-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
